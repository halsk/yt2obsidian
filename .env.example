ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
PORT=3456

# Where generated notes are written.
# Default: ~/workspace/obsidian/raw/articles
# OBSIDIAN_OUTPUT_DIR=/path/to/your/Vault/raw/articles

# Vault root used by the built-in git sync.
# Default: ~/workspace/obsidian
# OBSIDIAN_VAULT_DIR=/path/to/your/Vault

# Set to 1 to skip yt2obsidian's own git commit/push.
# Use when git is managed externally (e.g. the Obsidian github-sync /
# obsidian-git plugin) to avoid double-committer races on the same vault.
# OBSIDIAN_SKIP_GIT_SYNC=1
